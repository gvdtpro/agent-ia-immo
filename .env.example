# Clé API Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Token Telegram pour chaque client
# Format : TELEGRAM_TOKEN_{NOM_CLIENT_EN_MAJUSCULES}
TELEGRAM_TOKEN_DEMO=123456789:AAF...

# Token Notion (notion.so/my-integrations)
NOTION_TOKEN=secret_...

# Renseigné automatiquement par Railway
RAILWAY_PUBLIC_DOMAIN=ton-app.railway.app
